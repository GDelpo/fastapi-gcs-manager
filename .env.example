# =============================================================================
# FastAPI GCS Manager — Environment Variables
# =============================================================================

# Environment
DEBUG=false
LOG_FORMAT=json
# LOG_FILE=/app/logs/storage.log

# =============================================================================
# Google Cloud Storage
# =============================================================================
GCS_BUCKET_NAME=your-bucket-name
GCS_CREDENTIALS_PATH=/app/credentials/google_credentials.json
GCS_PROJECT_ID=
GCS_SIGNED_URL_EXPIRATION=60
GCS_LIFECYCLE_STANDARD_DAYS=90

# =============================================================================
# Identity Service (Token Validation)
# Leave empty and set SKIP_AUTH=true to run without external auth.
# =============================================================================
IDENTITY_SERVICE_URL=http://identity_api:8080/api/v1
IDENTITY_EXTERNAL_URL=http://localhost:8080/api/v1
SKIP_AUTH=false

# =============================================================================
# Optional: local source mount for bulk upload jobs
# (path inside the container; mount a host folder in docker-compose)
# =============================================================================
SOURCE_MOUNT_PATH=/app/source

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=["*"]

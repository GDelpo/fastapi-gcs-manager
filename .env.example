# =============================================================================
# Storage Service — Environment Variables
# =============================================================================

# Environment
DEBUG=false
LOG_FORMAT=json
# LOG_FILE=/app/logs/storage.log

# =============================================================================
# Google Cloud Storage
# =============================================================================
GCS_BUCKET_NAME=noble-polizas
GCS_CREDENTIALS_PATH=/app/credentials/google_credentials.json
GCS_PROJECT_ID=
GCS_SIGNED_URL_EXPIRATION=60
GCS_LIFECYCLE_STANDARD_DAYS=90

# =============================================================================
# Identity Service (Token Validation)
# =============================================================================
IDENTITY_SERVICE_URL=http://identidad_api:8080/api/v1
IDENTITY_EXTERNAL_URL=http://192.168.190.95/identidad/api/v1
SKIP_AUTH=false

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=["*"]
